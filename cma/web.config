<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Enable gzip compression for static and dynamic content -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />

        <!-- Default document settings -->
        <defaultDocument>
            <files>
                <clear />
                <add value="default.php" />
                <add value="index.php" />
                <add value="default.asp" />
                <add value="index.asp" />
            </files>
        </defaultDocument>

        <!-- Error handling - route 404 errors to custom handler -->
        <!-- existingResponse="Auto": only use custom error page if application returned empty body -->
        <!-- NEVER use "Replace" - it causes infinite loops when 404.php itself returns 404 status -->
        <httpErrors errorMode="Custom" existingResponse="Auto">
            <remove statusCode="404" />
            <error statusCode="404" path="/cma/404.php" responseMode="ExecuteURL" />
        </httpErrors>

        <!-- Remove X-Powered-By header -->
        <httpProtocol>
            <customHeaders>
                <remove name="X-Powered-By" />
            </customHeaders>
        </httpProtocol>

        <!-- Static content caching - 1 year for versioned assets (use ?v= for cache busting) -->
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            <!-- WebP image support (remove first to avoid duplicate error) -->
            <remove fileExtension=".webp" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
        </staticContent>

        <!-- URL Rewrite for clean URLs -->
        <!-- Requires IIS URL Rewrite Module: https://www.iis.net/downloads/microsoft/url-rewrite -->
        <!-- Note: These rules use the site-level _bootstrap_wrapper.php for proper autoloading -->
        <rewrite>
            <rules>
                <!-- Skip static file extensions - never rewrite document/media files -->
                <rule name="Skip static files" stopProcessing="true">
                    <match url="\.(docx?|xlsx?|pptx?|pdf|zip|rar|txt|csv|xml|json|jpg|jpeg|png|gif|webp|svg|ico|woff2?|ttf|eot|mp3|mp4|avi|mov)$" ignoreCase="true" />
                    <action type="None" />
                </rule>

                <!-- Redirect /cma/ root to /cma/dashboard (must be BEFORE skip files rule) -->
                <rule name="Root to Dashboard" stopProcessing="true">
                    <match url="^$" />
                    <action type="Redirect" url="/cma/dashboard" redirectType="Found" />
                </rule>

                <!-- /tools or /tools/ - must be BEFORE skip directories rule because tools/ is a physical directory -->
                <rule name="Tools Directory" stopProcessing="true">
                    <match url="^tools/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=tools.php" />
                </rule>

                <!-- Skip rewrite for existing files and directories -->
                <rule name="Skip existing files" stopProcessing="true">
                    <match url=".*" />
                    <conditions logicalGrouping="MatchAny">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
                    </conditions>
                    <action type="None" />
                </rule>

                <!-- /dashboard -->
                <rule name="Dashboard" stopProcessing="true">
                    <match url="^dashboard/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=dashboard.php" />
                </rule>

                <!-- /preferences -->
                <rule name="Preferences" stopProcessing="true">
                    <match url="^preferences/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=preferences.php" />
                </rule>

                <!-- /form/formname/recordId/subform/subformId/subsubform/subsubformId (3rd level detail) -->
                <rule name="Form with subsubform record" stopProcessing="true">
                    <match url="^form/([^/]+)/([^/]+)/([^/]+)/([^/]+)/([^/]+)/([^/]+)/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=form.php%3Fform%3D{R:1}&amp;formID={R:2}&amp;popup={R:3}&amp;popupID={R:4}&amp;subpopup={R:5}&amp;subpopupID={R:6}" />
                </rule>

                <!-- /form/formname/recordId/subform/subformId/subsubform (3rd level list) -->
                <rule name="Form with subsubform list" stopProcessing="true">
                    <match url="^form/([^/]+)/([^/]+)/([^/]+)/([^/]+)/([^/]+)/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=form.php%3Fform%3D{R:1}&amp;formID={R:2}&amp;popup={R:3}&amp;popupID={R:4}&amp;subpopup={R:5}" />
                </rule>

                <!-- /form/formname/recordId/subform/subformId -->
                <rule name="Form with subform record" stopProcessing="true">
                    <match url="^form/([^/]+)/([^/]+)/([^/]+)/([^/]+)/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=form.php%3Fform%3D{R:1}&amp;formID={R:2}&amp;popup={R:3}&amp;popupID={R:4}" />
                </rule>

                <!-- /form/formname/recordId/subform -->
                <rule name="Form with subform list" stopProcessing="true">
                    <match url="^form/([^/]+)/([^/]+)/([^/]+)/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=form.php%3Fform%3D{R:1}&amp;formID={R:2}&amp;popup={R:3}" />
                </rule>

                <!-- /form/formname/recordId (or /form/formname/new) -->
                <rule name="Form with record" stopProcessing="true">
                    <match url="^form/([^/]+)/([^/]+)/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=form.php%3Fform%3D{R:1}&amp;formID={R:2}" />
                </rule>

                <!-- /form/formname (list view) -->
                <rule name="Form list" stopProcessing="true">
                    <match url="^form/([^/]+)/?$" />
                    <serverVariables>
                        <set name="HTTP_X_ORIGINAL_FILE" value="/cma/main.php" />
                    </serverVariables>
                    <action type="Rewrite" url="/_bootstrap_wrapper.php?page=form.php%3Fform%3D{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>

    <!-- Cache settings for library directory and subdirectories -->
    <location path="library">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>
    <!-- Cache fonts for 1 year (fonts rarely change) -->
    <location path="library/fonts">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>
    <!-- Cache favicon for 1 year -->
    <location path="favicon.ico">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>
</configuration>
