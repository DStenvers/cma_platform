{"ts":"2026-01-18T11:26:12.910","level":"error","req":"8627fb54","msg":"Subform configuration error: parentField is empty and SQL has no [id] placeholder","ctx":{"parentFormId":"Rooster","subformName":"Evaluatie verzoeken","subformIndex":4,"jsonFormName":"rooster_evaluatie_verzoeken","parentId":"2443","sql":"SELECT tblEvalDeelname.ID, tblDeelnemers.VolledigeNaam AS Deelnemer, tblDocenten.VolledigeNaam AS Docent, tblEvalDocument.Naam AS SoortEvaluatie, lcase(format(tblEvalDeelname.datum_verzonden,'dd MMM yyyy')) as Datum_Verzonden, lcase(format(tblEvalDeelname.datum_reminder,'dd MMM yyyy')) as Datum_Reminder, lcase(format(tblEvalDeelname.datum_ingevuld,'dd MMM yyyy')) as Datum_Ingevuld\r\nFROM tblEvalDocument INNER JOIN (tblDocenten RIGHT JOIN (tblDeelnemers RIGHT JOIN tblEvalDeelname ON tblDeelnemers.ID = tblEvalDeelname.fkDeelnemer) ON tblDocenten.ID = tblEvalDeelname.fkDocent) ON tblEvalDocument.ID = tblEvalDeelname.fkEvalDocument\r\nORDER BY  tblEvalDocument.Naam, tblDeelnemers.VolledigeNaam, tblDocenten.VolledigeNaam;"},"url":"/cma/form_api.php?action=subforms&form=Rooster&ParentID=2443&indices=1,2,3,4","method":"GET","ip":"172.29.208.1"}
