en\" value=\"ddsadsa\" />\r\n<div class=\"formErrors\"></div>\r\n<div class=\"form__row\">\r\n<div class=\"col1\">\r\n<div class=\"form__fieldWrapper\">\r\n<label class=\"form__label\" for=\"voornaam_id\">Voornaam *</label>\r\n<input class=\"form__field\" data-required=\"Y\" id=\"voornaam_id\" name=\"voornaam\" type=\"text\" />\r\n<p class=\"field__errorMessage\"></p>\r\n</div>\r\n</div>\r\n<div class=\"col2\">\r\n<div class=\"form__fieldWrapper\">\r\n<label class=\"form__label\" for=\"achternaam_id\">Achternaam *</label>\r\n<input class=\"form__field\" data-required=\"Y\" id=\"achternaam_id\" name=\"achternaam\" type=\"text\" />\r\n<p class=\"field__errorMessage\"></p>\r\n</div>\r\n</div>\r\n</div>\r\n<div class=\"form__row\">\r\n<div class=\"col1\">\r\n<div class=\"form__fieldWrapper\">\r\n<label class=\"form__label\" for=\"telefoonnummer_id\">Telefoonnummer *</label>\r\n<input data-validation-type=\"telefoon\" class=\"form__field\" data-required=\"Y\" id=\"telefoonnummer_id\" name=\"telefoonnummer\" type=\"text\" />\r\n<p class=\"field__errorMessage\"></p>\r\n</div>\r\n</div>\r\n<div class=\"col2\">\r\n<div class=\"form__fieldWrapper\">\r\n<label class=\"form__label\" for=\"email_id\">Email *</label>\r\n<input class=\"form__field\" data-required=\"Y\" data-validation-type=\"email\" id=\"email_id\" name=\"email\" type=\"text\" />\r\n<p class=\"field__errorMessage\"></p>\r\n</div>\r\n</div>\r\n</div>\r\n<div class=\"form__fieldWrapper\">\r\n<label for=\"cv_id\" class=\"form__label\">CV *</label>\r\n<input type=\"hidden\" data-required=\"Y\" data-alwaysvalidate=\"Y\" name=\"required-cv\" id=\"cv_id\" data-label=\"CV\"/>\r\n<div class=\"fine-uploader fine-uploader_docs\" data-field=\"cv_id\" data-buttontext=\"Selecteer bestand\"></div>\r\n<p class=\"field__errorMessage\"></p>\r\n</div>\r\n<div class=\"form__fieldWrapper\">\r\n<label class=\"form__label\" for=\"motivatie_id\">Motivatiebrief *</label>\r\n<input type=\"hidden\" data-required=\"Y\" data-alwaysvalidate=\"Y\" name=\"required-motivatiebrief\" id=\"motivatiebrief_id\" data-label=\"Motivatiebrief\"/>\r\n<div class=\"fine-uploader fine-uploader_docs\" data-field=\"motivatiebrief_id\" data-buttontext=\"Selecteer bestand\"></div>\r\n<p class=\"field__errorMessage\"></p>\r\n</div>\r\n<div class=\"form__row\">\r\n<div class=\"form__fieldWrapper\">\r\n<div class=\"checkbox\">\r\n<input class=\"checkbox__input\" type=\"checkbox\" data-required=\"Y\" name=\"akkoord\" id=\"akkoord_id\" value=\"Ja\" />\r\n<label class=\"checkbox__label\" for=\"akkoord_id\"> Ik ga akkoord met de verwerking van mijn gegevens volgens het <a href=\"https://www.rinogroep.nl/uploads/html/sollicitatie_privacybeleid.pdf\" target=\"_blank\">privacybeleid</a>.<span id=\"email_info\"></span></label>\r\n</div>\r\n<p class=\"checkbox__errorMessage\"></p>\r\n</div>\r\n</div>\r\n<p>&nbsp;</p>\r\n<div class=\"form__submitWrapper\">\r\n<div class=\"form__submitInnerWrapper\">\r\n<input id=\"submit_btn\" type=\"button\" class=\"genericButton\" value=\"Solliciteer\" onclick=\"if (form_valid(document.forms.Solliciteer)){document.forms.Solliciteer.submit()}\"/>\r\n</div>\r\n</div>\r\n</form>\r\n</div></div><!--BLOCK{\"type\":\"Downloads\",\"variables\":[{\"downloads_label\":\"\",\"downloads_url\":\"\",\"downloads_extentie\":\"\",\"downloads_grootte\":\"\"}],\"visible\":true}--><div class=\"row\"><div class=\"cb cb--downloadsList col-xs-12 col-lg-8\"><div class=\"downloadsList\"><ul class=\"downloadsList__list\"><li class=\"downloadsList__listItem\"><a href=\"\" class=\"downloadsList__link\" target=\"_blank\"> <span class=\"downloadsList__filetype\">( )</span></a></li></ul></div></div></div><!--BLOCK{\"type\":\"Downloads\",\"variables\":[],\"visible\":true}--><div class=\"row\"><div class=\"cb cb--downloadsList col-xs-12 col-lg-8\"><div class=\"downloadsList\"><ul class=\"downloadsList__list\"></ul></div></div></div>","blockedit_1_longtext_body_text_1772113319972":"<p>Op deze pagina vind je algemene informatie gerelat