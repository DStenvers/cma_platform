{
    "name": "cma-cypress-tests",
    "version": "1.0.0",
    "description": "Cypress E2E tests for CMA application",
    "scripts": {
        "cypress:open": "cypress open",
        "cypress:run": "cypress run",
        "cypress:run:headed": "cypress run --headed",
        "test": "cypress run",
        "test:chrome": "cypress run --browser chrome",
        "test:firefox": "cypress run --browser firefox",
        "test:auth": "cypress run --spec 'cypress/e2e/auth.cy.js'",
        "test:forms": "cypress run --spec 'cypress/e2e/forms.cy.js'",
        "test:menu": "cypress run --spec 'cypress/e2e/menu.cy.js'",
        "test:sidebar": "cypress run --spec 'cypress/e2e/sidebar.cy.js'",
        "test:tools": "cypress run --spec 'cypress/e2e/tools.cy.js'",
        "test:search": "cypress run --spec 'cypress/e2e/search-panel.cy.js'",
        "test:inline": "cypress run --spec 'cypress/e2e/inline-edit.cy.js'",
        "test:preferences": "cypress run --spec 'cypress/e2e/preferences.cy.js'",
        "test:integration": "cypress run --spec 'cypress/e2e/integration/**/*.cy.js'",
        "test:components": "cypress run --spec 'cypress/e2e/components/**/*.cy.js'",
        "test:lib-table": "cypress run --spec 'cypress/e2e/components/lib-table.cy.js'",
        "test:menu-pages": "cypress run --spec 'cypress/e2e/navigation/menu-pages-load.cy.js'",
        "test:navigation": "cypress run --spec 'cypress/e2e/navigation/**/*.cy.js'",
        "test:dashboard": "cypress run --spec 'cypress/e2e/integration/dashboard.cy.js'",
        "test:reports": "cypress run --spec 'cypress/e2e/reports/**/*.cy.js'",
        "test:export": "cypress run --spec 'cypress/e2e/forms/export.cy.js'",
        "test:image-upload": "cypress run --spec 'cypress/e2e/forms/image-upload.cy.js'",
        "test:tools-page": "cypress run --spec 'cypress/e2e/tools/tools-page.cy.js'",
        "test:infinite-scroll": "cypress run --spec 'cypress/e2e/forms/infinite-scroll.cy.js'",
        "test:session": "cypress run --spec 'cypress/e2e/auth/session.cy.js'",
        "test:menu-icons": "cypress run --spec 'cypress/e2e/navigation/menu-icons.cy.js'",
        "test:all-auth": "cypress run --spec 'cypress/e2e/auth/**/*.cy.js'",
        "test:all-forms": "cypress run --spec 'cypress/e2e/forms/**/*.cy.js'",
        "test:all-tools": "cypress run --spec 'cypress/e2e/tools/**/*.cy.js'",
        "test:core": "cypress run --spec 'cypress/e2e/core/**/*.cy.js'",
        "test:utility": "cypress run --spec 'cypress/e2e/core/utility-functions.cy.js'",
        "test:table-funcs": "cypress run --spec 'cypress/e2e/core/table-functions.cy.js'",
        "test:form-helpers": "cypress run --spec 'cypress/e2e/core/form-helpers.cy.js'",
        "test:all": "cypress run",
        "test:storybook-icons": "cypress run --spec 'cypress/e2e/tools/storybook-icons.cy.js'",
        "build:icons": "python3 tools/build-icon-font.py",
        "build:minify": "bash tools/build-minify.sh",
        "build": "npm run build:icons && npm run build:minify"
    },
    "devDependencies": {
        "cypress": "^15.7.1",
        "terser": "^5.46.0"
    },
    "keywords": [
        "cypress",
        "testing",
        "e2e",
        "cma"
    ],
    "author": "CMA Team",
    "license": "UNLICENSED"
}
