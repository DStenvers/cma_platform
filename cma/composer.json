{
    "name": "app/cma",
    "description": "CMA - Content Management Application",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../helpers",
            "options": {
                "symlink": false
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require": {
        "php": ">=8.0",
        "app/helpers": "*",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9"
    },
    "scripts": {
        "test": "php tests/TestRunner.php"
    },
    "config": {
        "optimize-autoloader": true
    }
}
