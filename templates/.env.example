# Environment Configuration
# Copy this file to .env.local (development) or .env.production (production)

# Environment: L=Local, O=Development, T=Test, A=Acceptance, P=Production
APP_ENVIRONMENT=L

# Database paths (adjust to your project)
# DB_DATA_PATH=db/data.mdb
# DB_REP_PATH=db/repository.mdb
# DB_USERS_PATH=db/cmausers.sqlite

# Email settings
# SMTP_HOST=localhost
# SMTP_PORT=25

# Email logging (set to 1 to log all sent emails)
EMAIL_LOG_ENABLED=1

# CMA Debug mode (auto-enabled for O/L/T/A environments)
# CMA_DEBUG=0
