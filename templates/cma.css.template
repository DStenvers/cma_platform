/**
 * CMA branding and editor styles
 * This file is loaded by CKEditor as contentsCss and after all platform CSS.
 * Customize colors, fonts, and other project-specific styles here.
 * Lives outside cma/ so composer update doesn't overwrite it.
 */
body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #333;
}
